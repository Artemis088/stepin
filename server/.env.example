# Copy this file to ".env" (same folder) and fill in your values, then restart
# the backend (npm start). If .env is absent or SMTP is not filled in, the app
# runs in demo mode and shows the reset link on screen instead of emailing it.

# --- Email (Gmail SMTP) -----------------------------------------------------
# 1. Use a Google account with 2-Step Verification turned ON.
# 2. Create an "App password": Google account -> Security -> App passwords
#    -> pick "Mail" / "Other". Google gives you a 16-character password.
# 3. Put that 16-char password in SMTP_PASS (spaces optional).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=StepIn <youraddress@gmail.com>

# Base URL of the frontend, used to build the reset link in the email.
# On Render this is auto-detected (RENDER_EXTERNAL_URL); set it only to override.
APP_URL=http://localhost:5173

# --- Optional --------------------------------------------------------------
# Secret used to sign login tokens (any long random string).
# STEPIN_JWT_SECRET=change-me-to-a-long-random-string

# Path to the SQLite database file. Leave unset for local dev. On a hosted
# deploy with a persistent disk, point this at the mounted volume, e.g.
# STEPIN_DB_PATH=/var/data/stepin.db
